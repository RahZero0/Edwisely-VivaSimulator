# LLM provider options: ollama or groq.
LLM_PROVIDER=ollama

# Optional Groq setup for generation/evaluation.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=4096

# OpenAI embeddings are used by default for RAG indexing/retrieval.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Optional: set EMBEDDING_PROVIDER=ollama to keep using local Ollama embeddings
# for indexes created with the previous local setup.
EMBEDDING_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300

MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_CHUNKS=8

# Local Whisper transcription. Install openai-whisper separately before enabling.
ENABLE_WHISPER=false
WHISPER_MODEL=base
